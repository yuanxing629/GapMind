# ====================================================================
# GapMind environment variables
# Copy this file to backend/.env and fill in your keys.
# ====================================================================

# ---- App ----
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_STORAGE_DIR=./storage

# ---- PostgreSQL ----
POSTGRES_USER=gapmind
POSTGRES_PASSWORD=gapmind
POSTGRES_DB=gapmind
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://gapmind:gapmind@localhost:5432/gapmind

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- Milvus ----
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_PREFIX=gapmind_

# ---- LLM (Deepseek) ----
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# ---- Embedding (SiliconFlow, BGE-m3) ----
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# ---- Semantic Scholar ----
SEMANTIC_SCHOLAR_API_KEY=
SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1

# ---- CORS (frontend origin) ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
